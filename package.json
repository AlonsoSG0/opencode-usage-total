{
  "name": "opencode-usage-total",
  "version": "0.2.0",
  "description": "Track model usage, tokens, and costs per agent in the OpenCode TUI sidebar",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "image.png",
    "README.md",
    "README.en.md"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "tui",
    "usage",
    "tokens",
    "cost",
    "models"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlonsoSG0/opencode-usage-total.git"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.50 <2",
    "@opentui/core": ">=0.4.0 <0.5",
    "@opentui/solid": ">=0.4.0 <0.5",
    "solid-js": ">=1.9.12 <2"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.8",
    "@opentui/core": "^0.4.1",
    "@opentui/keymap": "^0.4.1",
    "@opentui/solid": "^0.4.1",
    "solid-js": "^1.9.12",
    "tsup": "^8.5.1",
    "vitest": "^4.1.9"
  }
}
